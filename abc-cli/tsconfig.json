{
  "extends": "../parse/tsconfig.json",
  "compilerOptions": {
    "outDir": "../out/abc-cli",
    "rootDir": ".",
    "composite": true,
    "tsBuildInfoFile": "../out/abc-cli/.tsbuildinfo",
    "skipLibCheck": true,
    "noResolve": false,
    "baseUrl": ".",
    "paths": {
      "abcls-parser/*": ["../parse/dist/*"],
      "abcls-midi": ["../midi/dist/src/index"]
    }
  },
  "include": ["*.ts", "commands/**/*.ts", "utils/**/*.ts"],
  "references": [{ "path": "../parse" }, { "path": "../midi" }]
}
