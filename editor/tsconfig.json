{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "../out/editor",
    "rootDir": ".",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "paths": {
      "abcls-cstree": ["../cstree/src/cstree"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "tests"],
  "references": [{ "path": "../parse" }, { "path": "../cstree" }]
}
