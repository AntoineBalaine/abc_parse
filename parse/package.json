{
  "name": "abc-parser",
  "displayName": "abc-parser",
  "description": "Abc notation parser",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./interpreter/*": {
      "types": "./dist/interpreter/*.d.ts",
      "default": "./dist/interpreter/*.js"
    },
    "./analyzers/*": {
      "types": "./dist/analyzers/*.d.ts",
      "default": "./dist/analyzers/*.js"
    },
    "./parsers/*": {
      "types": "./dist/parsers/*.d.ts",
      "default": "./dist/parsers/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./Visitors/fmt/*": {
      "types": "./dist/Visitors/fmt/*.d.ts",
      "default": "./dist/Visitors/fmt/*.js"
    },
    "./music-theory/*": {
      "types": "./dist/music-theory/*.d.ts",
      "default": "./dist/music-theory/*.js"
    },
    "./Visitors/*": {
      "types": "./dist/Visitors/*.d.ts",
      "default": "./dist/Visitors/*.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "default": "./dist/helpers.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^4.3.4",
    "@types/lodash": "^4.17.16",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.11.18",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "abcjs": "^6.5.2",
    "chai": "^4.3.7",
    "eslint": "^8.54.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.3.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "lint-staged": "^13.1.0",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc && node ./dist/Abc.js",
    "test": "mocha -r ts-node/register '**/*.spec.ts'",
    "test:scan": "mocha -r ts-node/register 'tests/scan_*.spec.ts'",
    "test:coverage": "nyc npm run test",
    "lint": "eslint . --ext ts",
    "lint:fix": "eslint . --ext ts --fix",
    "parse-folder": "ts-node tests/parseFolder.ts",
    "parse-file": "ts-node tests/parseFile.ts",
    "parse-folder:stringify": "ts-node tests/fmt_parseFolder_stringify.ts"
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "check-coverage": true,
    "all": true,
    "include": [
      "**/!(*.spec.*).[tj]s?(x)"
    ],
    "exclude": [
      "_tests_/**/*.*"
    ],
    "reporter": [
      "html",
      "lcov",
      "text",
      "text-summary"
    ],
    "report-dir": "../coverage"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^6.11.0",
    "fast-check": "^4.0.0",
    "lodash": "^4.17.21"
  }
}
